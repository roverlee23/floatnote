{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FloatNote",
  "version": "0.5.0",
  "identifier": "com.floatnote.notes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "FloatNote",
        "width": 420,
        "height": 560,
        "minWidth": 280,
        "minHeight": 320,
        "transparent": true,
        "alwaysOnTop": false,
        "decorations": false,
        "resizable": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
